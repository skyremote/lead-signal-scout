# lead-signal-scout — copy this file to ".env" and fill in your own keys.
# One KEY=VALUE per line. Never commit your real .env (see .gitignore).

# --- Discovery (required) ------------------------------------------------
# Exa: semantic web search that FINDS a person's public content. https://exa.ai
EXA_API_KEY=

# --- Deep page reads (optional) ------------------------------------------
# Firecrawl: only used with `--scrape` to read a full page. https://firecrawl.dev
FIRECRAWL_API_KEY=

# --- Scoring LLM (one of these is required) ------------------------------
# The tool defaults to Anthropic. To use another, set LLM_PROVIDER below.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# Optional overrides:
# LLM_PROVIDER=anthropic        # anthropic | openai | openrouter
# LLM_MODEL=claude-haiku-4-5    # any model id your provider supports
